[global]
    ### Display ###
    monitor = 0
    follow = mouse

    # Modern geometry (replaces the old `geometry`/`offset`/`notification_height`).
    width = (0, 320)         # shrink to content, up to 320px wide
    height = 120             # max height per notification
    origin = top-right
    offset = (16, 50)        # clear of the bar
    gap_size = 8             # space between stacked notifications
    notification_limit = 6

    indicate_hidden = yes
    transparency = 0
    separator_height = 2
    padding = 10
    horizontal_padding = 14
    frame_width = 2
    frame_color = "#CAA9E0"
    separator_color = frame
    corner_radius = 10
    sort = yes
    idle_threshold = 120

    ### Text ###
    font = JetBrains Mono Bold 10
    line_height = 1
    markup = full
    format = "<b>%s</b>\n%b"
    alignment = left
    show_age_threshold = 60
    word_wrap = yes
    ellipsize = middle
    ignore_newline = no
    stack_duplicates = true
    hide_duplicate_count = false
    show_indicators = yes

    ### Icons ###
    icon_position = left
    min_icon_size = 0
    max_icon_size = 48
    icon_path = /usr/share/icons/candy-icons/apps/scalable:/usr/share/icons/candy-icons/devices/scalable/

    ### History ###
    sticky_history = yes
    history_length = 20

    ### Misc/Advanced ###
    dmenu = /usr/bin/dmenu -p dunst:
    browser = /usr/bin/firefox -new-tab
    always_run_script = true
    title = Dunst
    class = Dunst
    corner_radius = 10
    force_xinerama = false

    ### Mouse ###
    mouse_left_click = close_current
    mouse_middle_click = do_action
    mouse_right_click = close_all

# NOTE: notification shortcuts are handled by qtile (Mod+` history, Mod+Shift+`
# clear-all) via dunstctl, so the old [shortcuts] section is removed.

[experimental]
    per_monitor_dpi = false

[urgency_low]
    background = "#282738"
    foreground = "#b9a3c9"
    frame_color = "#353446"
    timeout = 8

[urgency_normal]
    background = "#282738"
    foreground = "#CAA9E0"
    frame_color = "#CAA9E0"
    timeout = 8

[urgency_critical]
    background = "#282738"
    foreground = "#f28fad"
    frame_color = "#f28fad"
    timeout = 0          # critical alerts stay until dismissed (e.g. low battery)

# vim: ft=cfg
